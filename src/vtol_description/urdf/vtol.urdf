<?xml version="1.0"?>
<robot name="vtol_uav">

  <!-- ================= STRUCTURE ================= -->
  <link name="dummy_root"/>

  <joint name="dummy_joint" type="fixed">
    <parent link="dummy_root"/>
    <child link="base_link"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="0.5 0.2 0.1"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.5 0.2 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.00833" ixy="0.0" ixz="0.0" iyy="0.04333" iyz="0.0" izz="0.04833"/>
    </inertial>
  </link>

  <link name="left_wing">
    <visual>
      <origin xyz="0 0.4 0" rpy="0 0 0"/>
      <geometry><box size="0.15 0.8 0.02"/></geometry>
      <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>
    </visual>
    <inertial>
      <origin xyz="0 0.4 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.016" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0165"/>
    </inertial>
  </link>
  <joint name="base_to_left_wing" type="fixed">
    <parent link="base_link"/>
    <child link="left_wing"/>
    <origin xyz="0 0.1 0" rpy="0 0 0"/>
  </joint>

  <link name="right_wing">
    <visual>
      <origin xyz="0 -0.4 0" rpy="0 0 0"/>
      <geometry><box size="0.15 0.8 0.02"/></geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <origin xyz="0 -0.4 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.016" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0165"/>
    </inertial>
  </link>
  <joint name="base_to_right_wing" type="fixed">
    <parent link="base_link"/>
    <child link="right_wing"/>
    <origin xyz="0 -0.1 0" rpy="0 0 0"/>
  </joint>

  <link name="left_boom">
    <visual>
      <geometry><cylinder radius="0.015" length="0.6"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="wing_to_left_boom" type="fixed">
    <parent link="left_wing"/>
    <child link="left_boom"/>
    <origin xyz="0 0.4 0" rpy="0 1.5708 0"/>
  </joint>

  <link name="right_boom">
    <visual>
      <geometry><cylinder radius="0.015" length="0.6"/></geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="wing_to_right_boom" type="fixed">
    <parent link="right_wing"/>
    <child link="right_boom"/>
    <origin xyz="0 -0.4 0" rpy="0 1.5708 0"/>
  </joint>

  <!-- ================= HOVER ROTORS ================= -->
  <link name="rotor_fl">
    <visual>
      <geometry><cylinder radius="0.15" length="0.01"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 0.8 0.7"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00028" ixy="0" ixz="0" iyy="0.00028" iyz="0" izz="0.00056"/>
    </inertial>
  </link>
  <joint name="joint_rotor_fl" type="continuous">
    <parent link="left_boom"/>
    <child link="rotor_fl"/>
    <origin xyz="0 0 0.3" rpy="0 -1.5708 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rotor_rl">
    <visual>
      <geometry><cylinder radius="0.15" length="0.01"/></geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00028" ixy="0" ixz="0" iyy="0.00028" iyz="0" izz="0.00056"/>
    </inertial>
  </link>
  <joint name="joint_rotor_rl" type="continuous">
    <parent link="left_boom"/>
    <child link="rotor_rl"/>
    <origin xyz="0 0 -0.3" rpy="0 -1.5708 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rotor_fr">
    <visual>
      <geometry><cylinder radius="0.15" length="0.01"/></geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00028" ixy="0" ixz="0" iyy="0.00028" iyz="0" izz="0.00056"/>
    </inertial>
  </link>
  <joint name="joint_rotor_fr" type="continuous">
    <parent link="right_boom"/>
    <child link="rotor_fr"/>
    <origin xyz="0 0 0.3" rpy="0 -1.5708 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rotor_rr">
    <visual>
      <geometry><cylinder radius="0.15" length="0.01"/></geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00028" ixy="0" ixz="0" iyy="0.00028" iyz="0" izz="0.00056"/>
    </inertial>
  </link>
  <joint name="joint_rotor_rr" type="continuous">
    <parent link="right_boom"/>
    <child link="rotor_rr"/>
    <origin xyz="0 0 -0.3" rpy="0 -1.5708 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ================= PUSHER ================= -->
  <link name="rotor_pusher">
    <visual>
      <geometry><cylinder radius="0.1" length="0.02"/></geometry>
      <material name="red"><color rgba="0.8 0.0 0.0 0.7"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>
  <joint name="joint_rotor_pusher" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_pusher"/>
    <origin xyz="-0.26 0 0" rpy="0 1.5708 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ================= ROS2 CONTROL ================= -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="joint_rotor_fl">
      <command_interface name="velocity">
        <param name="min">-2000</param>
        <param name="max">2000</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_rotor_fr">
      <command_interface name="velocity">
        <param name="min">-2000</param>
        <param name="max">2000</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_rotor_rl">
      <command_interface name="velocity">
        <param name="min">-2000</param>
        <param name="max">2000</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_rotor_rr">
      <command_interface name="velocity">
        <param name="min">-2000</param>
        <param name="max">2000</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_rotor_pusher">
      <command_interface name="velocity">
        <param name="min">-2000</param>
        <param name="max">2000</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find vtol_control)/config/vtol_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- ================= FORCE PLUGINS ================= -->
  <gazebo>
    <plugin name="force_fl" filename="libgazebo_ros_force.so">
      <ros>
        <namespace>/vtol_uav</namespace>
        <remapping>gazebo_ros_force:=force_fl</remapping>
      </ros>
      <link_name>rotor_fl</link_name>
      <force_frame>link</force_frame>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="force_fr" filename="libgazebo_ros_force.so">
      <ros>
        <namespace>/vtol_uav</namespace>
        <remapping>gazebo_ros_force:=force_fr</remapping>
      </ros>
      <link_name>rotor_fr</link_name>
      <force_frame>link</force_frame>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="force_rl" filename="libgazebo_ros_force.so">
      <ros>
        <namespace>/vtol_uav</namespace>
        <remapping>gazebo_ros_force:=force_rl</remapping>
      </ros>
      <link_name>rotor_rl</link_name>
      <force_frame>link</force_frame>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="force_rr" filename="libgazebo_ros_force.so">
      <ros>
        <namespace>/vtol_uav</namespace>
        <remapping>gazebo_ros_force:=force_rr</remapping>
      </ros>
      <link_name>rotor_rr</link_name>
      <force_frame>link</force_frame>
    </plugin>
  </gazebo>

  <!-- ================= IMU ================= -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>/vtol_uav</namespace>
          <remapping>~/out:=imu</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ================= GROUND TRUTH (GPS) ================= -->
  <gazebo>
    <plugin name="ground_truth_sensor" filename="libgazebo_ros_p3d.so">
      <ros>
        <namespace>/vtol_uav</namespace>
        <remapping>odom:=ground_truth</remapping>
      </ros>
      <body_name>dummy_root</body_name>
      <frame_name>world</frame_name>
      <update_rate>50.0</update_rate>
    </plugin>
  </gazebo>

</robot>
